<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{QUERY_STRING} token=(.*)
    RewriteRule index.html  %1
    RewriteRule ^(.*)$ index.php/$1 [QSA,PT,L]
</IfModule>