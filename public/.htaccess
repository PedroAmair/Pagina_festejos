<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^([A-Za-z0-9-]+)$ /confirmar-cuenta?token=$1
    RewriteRule ^(.*)$ index.php/$2 [QSA,PT,L]
</IfModule>